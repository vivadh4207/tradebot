# =============================================================================
# tradebot .env.example  —  COMMITTED TEMPLATE (no real secrets)
# Copy to .env and fill in real values. .env is gitignored.
# =============================================================================


# -----------------------------------------------------------------------------
# Alpaca (paper by default)
# -----------------------------------------------------------------------------
ALPACA_API_KEY_ID=your_alpaca_paper_key_id
ALPACA_API_SECRET_KEY=your_alpaca_paper_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets


# -----------------------------------------------------------------------------
# CockroachDB  —  pick ONE of the two options below
# -----------------------------------------------------------------------------

# --- Option A: full connection string (simplest) ---
# postgresql://USER:PASSWORD@HOST:26257/DATABASE?sslmode=verify-full&sslrootcert=/path/to/root.crt
COCKROACH_DSN=

# --- Option B: individual fields (used only when COCKROACH_DSN is blank) ---
COCKROACH_HOST=your_cluster_host.cockroachlabs.cloud
COCKROACH_PORT=26257
COCKROACH_USER=your_db_user
COCKROACH_PASSWORD=your_db_password
COCKROACH_DATABASE=tradebot
COCKROACH_SSLMODE=verify-full
COCKROACH_SSLROOTCERT=
COCKROACH_CLUSTER=


# -----------------------------------------------------------------------------
# Optional integrations
# -----------------------------------------------------------------------------
NEWSAPI_KEY=
FINNHUB_KEY=
ANTHROPIC_API_KEY=

# Notifier (set ONE — Discord takes precedence if both are set)
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=


# -----------------------------------------------------------------------------
# Master switch. MUST stay false until 30+ days of paper validation have passed.
# -----------------------------------------------------------------------------
LIVE_TRADING=false
