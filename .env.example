# =============================================================================
# tradebot .env.example  —  COMMITTED TEMPLATE (no real secrets)
# Copy to .env and fill in real values. .env is gitignored.
# =============================================================================


# -----------------------------------------------------------------------------
# Alpaca (paper by default)
# -----------------------------------------------------------------------------
ALPACA_API_KEY_ID=your_alpaca_paper_key_id
ALPACA_API_SECRET_KEY=your_alpaca_paper_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets


# -----------------------------------------------------------------------------
# Storage: local SQLite only. No DB credentials needed.
# Path is configured in config/settings.yaml::storage.sqlite_path.
# On Jetson, TRADEBOT_DATA_ROOT below relocates the whole footprint to
# the SD card without touching YAML.
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
# Data root (Jetson SD-card mode). When set, EVERY persistent path —
# SQLite journal, LSTM checkpoints, LLM GGUF models, data cache — is
# resolved under this root instead of the repo. Leave blank for a
# laptop / Mac install.
#
#   Example: TRADEBOT_DATA_ROOT=/media/orin/tradebot-data
# -----------------------------------------------------------------------------
TRADEBOT_DATA_ROOT=


# -----------------------------------------------------------------------------
# Local LLM (Jetson). Three separate concerns:
#
#   LLM_BRAIN_ENABLED=1          enables the 8B review layer
#   LLM_BRAIN_HARD_GATE=1        allows the 8B to veto trades (opt-in)
#   LLM_MODEL_PATH=...           overrides model path for the 8B brain
#   LLM_AUDITOR_MODEL_PATH=...   overrides model path for the 70B auditor
#
# Defaults: both models auto-resolve under
#   $TRADEBOT_DATA_ROOT/models/llama-3.1-8b-q4.gguf
#   $TRADEBOT_DATA_ROOT/models/llama-3.1-70b-q4.gguf
# -----------------------------------------------------------------------------
LLM_BRAIN_ENABLED=0
LLM_BRAIN_HARD_GATE=0
LLM_MODEL_PATH=
LLM_AUDITOR_MODEL_PATH=


# -----------------------------------------------------------------------------
# Optional integrations
# -----------------------------------------------------------------------------
NEWSAPI_KEY=
FINNHUB_KEY=
ANTHROPIC_API_KEY=

# Notifier — Discord takes precedence over Slack if both set.
#
# SINGLE-CHANNEL mode: set just DISCORD_WEBHOOK_URL. All messages go
# to that one channel. Gets noisy fast.
#
# MULTI-CHANNEL mode (recommended). Create separate Discord channels,
# give each its own webhook, and paste the URLs here. Missing channels
# fall back to DISCORD_WEBHOOK_URL.
#
# Routing by message title:
#   entry / exit
#     → DISCORD_WEBHOOK_URL_TRADES       (#tradebot-trades)
#       Entry embed includes full rationale:
#       strike, dte, delta, iv, regime, sig_score, 5bar_move,
#       vol_ratio, spot, vwap, bid, ask, auto_PT, auto_SL, qty_policy
#       — everything you need to post-mortem a trade.
#   catalysts
#     → DISCORD_WEBHOOK_URL_CATALYSTS    (#tradebot-catalysts, off by default)
#   HALT / watchdog / shutdown / reconcile / error / risk / startup
#     → DISCORD_WEBHOOK_URL_ALERTS       (#tradebot-alerts)
#   calibration ratio drift
#     → DISCORD_WEBHOOK_URL_CALIBRATION  (#tradebot-calibration, optional)
#   nightly walk-forward report / edge verdict / regime-shift notes
#     → DISCORD_WEBHOOK_URL_REASON       (#tradebot-reason)
#       This is the "why trade at all" channel — low-frequency,
#       high-signal. Whether the strategy has measurable edge.
#   everything else (EOD summary, etc.)
#     → DISCORD_WEBHOOK_URL              (default fallback)
#
# Noise toggles (config/settings.yaml → notifier.*):
#   startup_notify: false       (bot-startup pings stay in log only)
#   catalysts_notify: false     (daily catalyst list stays in log only)
#   reconcile_notify: false     (zombie-close reports stay in log only)
# Set to true in settings.yaml if you want those pushed.
#
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_URL_TRADES=
DISCORD_WEBHOOK_URL_CATALYSTS=
DISCORD_WEBHOOK_URL_ALERTS=
DISCORD_WEBHOOK_URL_CALIBRATION=
DISCORD_WEBHOOK_URL_REASON=
SLACK_WEBHOOK_URL=

# --- Operator-defined extra channels ---
# Every `DISCORD_WEBHOOK_URL_<NAME>` env becomes a channel keyed by the
# lowercased <NAME>. No code change required. Point titles at these
# via DISCORD_EXTRA_CHANNEL_ROUTES (comma-separated title:channel pairs).
# Example using 5 new webhooks:
#
#   DISCORD_WEBHOOK_URL_POLITICAL=https://discord.com/api/webhooks/.../...
#   DISCORD_WEBHOOK_URL_LLM=https://discord.com/api/webhooks/.../...
#   DISCORD_WEBHOOK_URL_OPTIONS=https://discord.com/api/webhooks/.../...
#   DISCORD_WEBHOOK_URL_MACRO=https://discord.com/api/webhooks/.../...
#   DISCORD_WEBHOOK_URL_TERMINAL=https://discord.com/api/webhooks/.../...
#   DISCORD_EXTRA_CHANNEL_ROUTES=political_alert:political,llm_review:llm,options_flow:options,macro_event:macro,bot_command:terminal
#
DISCORD_WEBHOOK_URL_POLITICAL=
DISCORD_WEBHOOK_URL_LLM=
DISCORD_WEBHOOK_URL_OPTIONS=
DISCORD_WEBHOOK_URL_MACRO=
DISCORD_WEBHOOK_URL_TERMINAL=
DISCORD_EXTRA_CHANNEL_ROUTES=


# --- Discord terminal bot (interactive button panel + !commands) ---
# Separate from webhooks — this is a real Bot Application that listens
# in channels and can POST buttons (webhooks cannot post buttons).
#
# Setup (one time):
#   1. https://discord.com/developers/applications → New Application
#   2. Bot tab → Reset Token → copy to DISCORD_BOT_TOKEN below
#   3. Bot tab → enable "Message Content Intent"
#   4. OAuth2 → URL Generator → scope: bot, permissions: Send Messages +
#      Read Message History → open URL → add bot to your server
#   5. In Discord: right-click each channel you want buttons in → Copy
#      Channel ID (needs Developer Mode on: User Settings → Advanced)
#   6. Your user ID: right-click yourself → Copy User ID
#   7. Paste IDs below. IDs are comma-separated; add as many channels
#      as you want buttons in.
#   8. Run: bash scripts/tradebotctl.sh discord-install
#   9. In any channel the bot is in, type: !panel
#      (bot posts a control-panel message with clickable buttons)
DISCORD_BOT_TOKEN=
DISCORD_TERMINAL_CHANNEL_IDS=
DISCORD_TERMINAL_AUTHORIZED_USERS=
DISCORD_TERMINAL_PREFIX=!


# -----------------------------------------------------------------------------
# Dashboard process controls. OFF by default — the dashboard has no auth,
# so exposing start/stop/restart buttons on a bound port lets anyone on
# the network kill the bot. Only flip to 1 when (a) the dashboard is
# bound to 127.0.0.1 AND (b) you're the only user on this host.
# -----------------------------------------------------------------------------
TRADEBOT_DASHBOARD_CONTROLS=0


# -----------------------------------------------------------------------------
# Per-signal audit log. When 1, every SignalSource.emit() writes a line
# to logs/signal_audit.jsonl (or TRADEBOT_SIGNAL_AUDIT_PATH). Used for
# post-hoc analysis of which sources fire / which get blocked. No I/O
# overhead when 0 (the default).
# -----------------------------------------------------------------------------
TRADEBOT_SIGNAL_AUDIT=0


# -----------------------------------------------------------------------------
# TradingView webhook. When set, POST /webhook/tradingview on the
# dashboard accepts alert payloads whose "secret" field matches. Alerts
# are journaled to logs/tradingview_queue.jsonl and consumed by the
# TradingViewWebhookSignal source on each bot tick.
#
# Set a long random value — this is the only thing between attackers and
# your signal feed. Rotate if it leaks:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# If blank, the endpoint returns 503 and the signal source is skipped.
# -----------------------------------------------------------------------------
TRADINGVIEW_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# Master switch. MUST stay false until 30+ days of paper validation have passed.
# -----------------------------------------------------------------------------
LIVE_TRADING=false
