# =============================================================================
# tradebot .env.example  —  COMMITTED TEMPLATE (no real secrets)
# Copy to .env and fill in real values. .env is gitignored.
# =============================================================================


# -----------------------------------------------------------------------------
# Alpaca (paper by default)
# -----------------------------------------------------------------------------
ALPACA_API_KEY_ID=your_alpaca_paper_key_id
ALPACA_API_SECRET_KEY=your_alpaca_paper_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets


# -----------------------------------------------------------------------------
# CockroachDB  —  pick ONE of the two options below
# -----------------------------------------------------------------------------

# --- Option A: full connection string (simplest) ---
# postgresql://USER:PASSWORD@HOST:26257/DATABASE?sslmode=verify-full&sslrootcert=/path/to/root.crt
COCKROACH_DSN=

# --- Option B: individual fields (used only when COCKROACH_DSN is blank) ---
COCKROACH_HOST=your_cluster_host.cockroachlabs.cloud
COCKROACH_PORT=26257
COCKROACH_USER=your_db_user
COCKROACH_PASSWORD=your_db_password
COCKROACH_DATABASE=tradebot
COCKROACH_SSLMODE=verify-full
COCKROACH_SSLROOTCERT=
COCKROACH_CLUSTER=


# -----------------------------------------------------------------------------
# Optional integrations
# -----------------------------------------------------------------------------
NEWSAPI_KEY=
FINNHUB_KEY=
ANTHROPIC_API_KEY=

# Notifier — Discord takes precedence over Slack if both set.
#
# SINGLE-CHANNEL mode: set just DISCORD_WEBHOOK_URL. All messages go
# to that one channel. Gets noisy fast.
#
# MULTI-CHANNEL mode (recommended). Create separate Discord channels,
# give each its own webhook, and paste the URLs here. Missing channels
# fall back to DISCORD_WEBHOOK_URL.
#
# Routing by message title:
#   entry / exit
#     → DISCORD_WEBHOOK_URL_TRADES       (#tradebot-trades)
#       Entry embed includes full rationale:
#       strike, dte, delta, iv, regime, sig_score, 5bar_move,
#       vol_ratio, spot, vwap, bid, ask, auto_PT, auto_SL, qty_policy
#       — everything you need to post-mortem a trade.
#   catalysts
#     → DISCORD_WEBHOOK_URL_CATALYSTS    (#tradebot-catalysts, off by default)
#   HALT / watchdog / shutdown / reconcile / error / risk / startup
#     → DISCORD_WEBHOOK_URL_ALERTS       (#tradebot-alerts)
#   calibration ratio drift
#     → DISCORD_WEBHOOK_URL_CALIBRATION  (#tradebot-calibration, optional)
#   everything else (EOD summary, etc.)
#     → DISCORD_WEBHOOK_URL              (default fallback)
#
# Noise toggles (config/settings.yaml → notifier.*):
#   startup_notify: false       (bot-startup pings stay in log only)
#   catalysts_notify: false     (daily catalyst list stays in log only)
#   reconcile_notify: false     (zombie-close reports stay in log only)
# Set to true in settings.yaml if you want those pushed.
#
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_URL_TRADES=
DISCORD_WEBHOOK_URL_CATALYSTS=
DISCORD_WEBHOOK_URL_ALERTS=
DISCORD_WEBHOOK_URL_CALIBRATION=
SLACK_WEBHOOK_URL=


# -----------------------------------------------------------------------------
# Master switch. MUST stay false until 30+ days of paper validation have passed.
# -----------------------------------------------------------------------------
LIVE_TRADING=false
