# --------------------------------------------------------------- template
# Copy to `.env` and fill in the real values. `.env` is gitignored;
# `.env.example` is safe to commit — it must contain NO real secrets.
# --------------------------------------------------------------- template


# ---------- broker / data ----------
# Paper-trading-first. LIVE_TRADING=false is the default; never flip
# without a staged migration.
LIVE_TRADING=false

ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets


# ---------- per-host data root ----------
# Jetson example: external SD card mount
# TRADEBOT_DATA_ROOT=/media/viv/5b20ae3e-3632-4382-8576-e062366781e3/tradebot
TRADEBOT_DATA_ROOT=


# ---------- LLMs (Ollama on Jetson) ----------
# Set to `ollama` to use the local daemon at http://127.0.0.1:11434.
# The `llama_cpp` backend loads a GGUF file directly and is the Mac
# fallback; on Jetson use ollama.
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434

# 8B — per-trade brain (review/synthesis layer on every entry)
LLM_BRAIN_MODEL=llama3.1:8b

# 70B — nightly strategy auditor + on-demand dashboard button
LLM_AUDITOR_MODEL=llama3.1:70b


# ---------- LLM chat in Discord ----------
LLM_CHAT_ENABLED=1
LLM_CHAT_MODEL=llama3.1:8b           # default model for free-form Q&A
LLM_CHAT_RATE_LIMIT_PER_MIN=10

# Per-channel 70B routing — channels in this set use the 70B instead
# of the 8B for detailed answers. Must also be in
# DISCORD_TERMINAL_CHANNEL_IDS.
#
#   DISCORD_CHAT_70B_CHANNELS=123456789012345678,234567890123456789
DISCORD_CHAT_70B_CHANNELS=
LLM_CHAT_70B_MODEL=llama3.1:70b      # overrides LLM_AUDITOR_MODEL for chat
LLM_CHAT_70B_MAX_TOKENS=700          # 70B answers want more headroom
LLM_CHAT_70B_TIMEOUT_SEC=180


# ---------- Discord terminal (remote control) ----------
DISCORD_BOT_TOKEN=

# Bot listens in ANY channel whose ID appears here. Comma-separated.
# The startup hello posts once into each.
DISCORD_TERMINAL_CHANNEL_IDS=

# Who is allowed to run commands / use buttons / ask the LLM.
# Anyone not listed gets "Not authorized."
DISCORD_TERMINAL_AUTHORIZED_USERS=

DISCORD_TERMINAL_PREFIX=!


# ---------- Discord webhooks (notifications) ----------
# One URL per title. The notifier dispatches by message title.
DISCORD_WEBHOOK_URL=                  # default / catch-all
# DISCORD_WEBHOOK_URL_EDGE_REPORT=
# DISCORD_WEBHOOK_URL_TRADES=
# DISCORD_WEBHOOK_URL_ERRORS=

# Optional extra title→URL routing: comma-separated `title:url` pairs.
# Lower priority than DISCORD_WEBHOOK_URL_<NAME>.
DISCORD_EXTRA_CHANNEL_ROUTES=


# ---------- political news (70B auditor context) ----------
POLITICAL_NEWS_ENABLED=0
# ALPACA_NEWS_URL=https://data.alpaca.markets/v1beta1/news
# POLITICAL_NEWS_RSS_URLS=https://feeds.example.com/x-user,https://example.com/rss


# ---------- dashboard ----------
# Start/stop/reset buttons off unless set.
TRADEBOT_DASHBOARD_CONTROLS=0
