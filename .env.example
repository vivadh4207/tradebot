# =============================================================================
# tradebot .env.example  —  COMMITTED TEMPLATE (no real secrets)
# Copy to .env and fill in real values. .env is gitignored.
# =============================================================================


# -----------------------------------------------------------------------------
# Alpaca (paper by default)
# -----------------------------------------------------------------------------
ALPACA_API_KEY_ID=your_alpaca_paper_key_id
ALPACA_API_SECRET_KEY=your_alpaca_paper_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets


# -----------------------------------------------------------------------------
# Storage: local SQLite only. No DB credentials needed.
# Path is configured in config/settings.yaml::storage.sqlite_path.
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
# Optional integrations
# -----------------------------------------------------------------------------
NEWSAPI_KEY=
FINNHUB_KEY=
ANTHROPIC_API_KEY=

# Notifier — Discord takes precedence over Slack if both set.
#
# SINGLE-CHANNEL mode: set just DISCORD_WEBHOOK_URL. All messages go
# to that one channel. Gets noisy fast.
#
# MULTI-CHANNEL mode (recommended). Create separate Discord channels,
# give each its own webhook, and paste the URLs here. Missing channels
# fall back to DISCORD_WEBHOOK_URL.
#
# Routing by message title:
#   entry / exit
#     → DISCORD_WEBHOOK_URL_TRADES       (#tradebot-trades)
#       Entry embed includes full rationale:
#       strike, dte, delta, iv, regime, sig_score, 5bar_move,
#       vol_ratio, spot, vwap, bid, ask, auto_PT, auto_SL, qty_policy
#       — everything you need to post-mortem a trade.
#   catalysts
#     → DISCORD_WEBHOOK_URL_CATALYSTS    (#tradebot-catalysts, off by default)
#   HALT / watchdog / shutdown / reconcile / error / risk / startup
#     → DISCORD_WEBHOOK_URL_ALERTS       (#tradebot-alerts)
#   calibration ratio drift
#     → DISCORD_WEBHOOK_URL_CALIBRATION  (#tradebot-calibration, optional)
#   nightly walk-forward report / edge verdict / regime-shift notes
#     → DISCORD_WEBHOOK_URL_REASON       (#tradebot-reason)
#       This is the "why trade at all" channel — low-frequency,
#       high-signal. Whether the strategy has measurable edge.
#   everything else (EOD summary, etc.)
#     → DISCORD_WEBHOOK_URL              (default fallback)
#
# Noise toggles (config/settings.yaml → notifier.*):
#   startup_notify: false       (bot-startup pings stay in log only)
#   catalysts_notify: false     (daily catalyst list stays in log only)
#   reconcile_notify: false     (zombie-close reports stay in log only)
# Set to true in settings.yaml if you want those pushed.
#
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_URL_TRADES=
DISCORD_WEBHOOK_URL_CATALYSTS=
DISCORD_WEBHOOK_URL_ALERTS=
DISCORD_WEBHOOK_URL_CALIBRATION=
DISCORD_WEBHOOK_URL_REASON=
SLACK_WEBHOOK_URL=


# -----------------------------------------------------------------------------
# Dashboard process controls. OFF by default — the dashboard has no auth,
# so exposing start/stop/restart buttons on a bound port lets anyone on
# the network kill the bot. Only flip to 1 when (a) the dashboard is
# bound to 127.0.0.1 AND (b) you're the only user on this host.
# -----------------------------------------------------------------------------
TRADEBOT_DASHBOARD_CONTROLS=0


# -----------------------------------------------------------------------------
# Per-signal audit log. When 1, every SignalSource.emit() writes a line
# to logs/signal_audit.jsonl (or TRADEBOT_SIGNAL_AUDIT_PATH). Used for
# post-hoc analysis of which sources fire / which get blocked. No I/O
# overhead when 0 (the default).
# -----------------------------------------------------------------------------
TRADEBOT_SIGNAL_AUDIT=0


# -----------------------------------------------------------------------------
# TradingView webhook. When set, POST /webhook/tradingview on the
# dashboard accepts alert payloads whose "secret" field matches. Alerts
# are journaled to logs/tradingview_queue.jsonl and consumed by the
# TradingViewWebhookSignal source on each bot tick.
#
# Set a long random value — this is the only thing between attackers and
# your signal feed. Rotate if it leaks:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# If blank, the endpoint returns 503 and the signal source is skipped.
# -----------------------------------------------------------------------------
TRADINGVIEW_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# Master switch. MUST stay false until 30+ days of paper validation have passed.
# -----------------------------------------------------------------------------
LIVE_TRADING=false
