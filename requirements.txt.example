# Canonical dependency template. Copy to `requirements.txt` on first
# install:
#
#   cp requirements.txt.example requirements.txt
#   .venv/bin/pip install -r requirements.txt
#
# requirements.txt is gitignored (per-host) so each host (Mac laptop,
# Jetson Orin) can layer on its own wheels — e.g. the Jetson needs
# NVIDIA's aarch64 PyTorch build, llama-cpp-python compiled with
# CUDA, and jetson-stats for telemetry; none of those belong on a Mac.

# Core
numpy>=1.26
pandas>=2.1
scipy>=1.11
pytz>=2024.1
python-dateutil>=2.8

# Data + config
pyyaml>=6.0
python-dotenv>=1.0

# Stats / modeling
statsmodels>=0.14

# Brokers (optional - alpaca only needed for paper/live)
alpaca-py>=0.21

# Market data fallbacks
yfinance>=0.2.40
requests>=2.31

# Utilities
structlog>=24.1

# Storage: stdlib sqlite3 only — no external deps required.

# Discord terminal bot (optional — only needed if you run the terminal).
# Not in the hot path; the webhook notifier alone does not need this.
discord.py>=2.3

# Dashboard
fastapi>=0.110
uvicorn[standard]>=0.29
httpx>=0.27                   # required by FastAPI TestClient + async HTTP

# Config schema validation
pydantic>=2.0

# Testing
pytest>=8.0
pytest-asyncio>=0.23

