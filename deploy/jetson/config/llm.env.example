# Append these to your .env once download_model.sh finishes.
# They flip the bot to local LLM inference instead of calling Anthropic.

# Full path to the quantized GGUF file (set by download_model.sh)
LLM_MODEL_PATH=/home/orin/tradebot/deploy/jetson/models/qwen2.5-7b-instruct-q4_k_m.gguf

# Offload every transformer layer to GPU (-1 = all). Orin has 2048 CUDA cores.
LLM_N_GPU_LAYERS=-1

# Context window — 4096 is plenty for the headline prompts we build.
LLM_N_CTX=4096

# CPU threads if the model had to fall back to CPU-only. Orin has 12 cores.
LLM_N_THREADS=8

# Low temperature = near-deterministic classifications.
LLM_TEMPERATURE=0.1
