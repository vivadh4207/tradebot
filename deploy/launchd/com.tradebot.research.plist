<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  macOS launchd agent: fires the options-research agent every 30 min
  during US market hours (09:30-16:00 ET). Posts to Discord via the
  MultiChannelNotifier. Runs the 70B LLM so this takes 30-180s per
  invocation — that's why we spread it every 30 min, not every tick.

  Install:  scripts/tradebotctl.sh research-install
  Status:   launchctl list | grep tradebot.research
  Logs:     logs/options_research.out / .err
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.tradebot.research</string>

  <key>WorkingDirectory</key>
  <string>__TRADEBOT_ROOT__</string>

  <key>ProgramArguments</key>
  <array>
    <string>__TRADEBOT_PY__</string>
    <string>__TRADEBOT_ROOT__/scripts/run_options_research.py</string>
    <string>--symbols</string>
    <string>SPY,QQQ</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    <key>TZ</key>
    <string>America/New_York</string>
  </dict>

  <!-- Fire at :00 and :30 past every hour between 09:30 and 16:00 ET
       on weekdays. launchd takes an array of StartCalendarInterval
       dicts; each dict is a separate trigger. -->
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Weekday</key><integer>1</integer><key>Hour</key><integer>9</integer><key>Minute</key><integer>30</integer></dict>
    <dict><key>Weekday</key><integer>1</integer><key>Hour</key><integer>10</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Weekday</key><integer>1</integer><key>Hour</key><integer>10</integer><key>Minute</key><integer>30</integer></dict>
