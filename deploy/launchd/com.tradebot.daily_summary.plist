<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Daily session summary — fires 16:30 ET weekdays, after EOD flatten.
  Writes logs/daily_summary_YYYY-MM-DD.{md,json} and posts the md to
  the Discord audit channel (DISCORD_WEBHOOK_URL_AUDIT or fallback).

  The .md is what tomorrow's audit-LLM session reads to flag bugs and
  anomalies. Don't disable — it's the operator's daily journal.

  Install via tradebotctl.sh after replacing __TRADEBOT_ROOT__.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.tradebot.daily_summary</string>

  <key>WorkingDirectory</key>
  <string>__TRADEBOT_ROOT__</string>

  <key>ProgramArguments</key>
  <array>
    <string>__TRADEBOT_PY__</string>
    <string>__TRADEBOT_ROOT__/scripts/generate_daily_summary.py</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    <key>TZ</key>
    <string>America/New_York</string>
  </dict>

  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Weekday</key><integer>1</integer><key>Hour</key><integer>16</integer><key>Minute</key><integer>30</integer></dict>
    <dict><key>Weekday</key><integer>2</integer><key>Hour</key><integer>16</integer><key>Minute</key><integer>30</integer></dict>
    <dict><key>Weekday</key><integer>3</integer><key>Hour</key><integer>16</integer><key>Minute</key><integer>30</integer></dict>
    <dict><key>Weekday</key><integer>4</integer><key>Hour</key><integer>16</integer><key>Minute</key><integer>30</integer></dict>
    <dict><key>Weekday</key><integer>5</integer><key>Hour</key><integer>16</integer><key>Minute</key><integer>30</integer></dict>
  </array>

  <key>StandardOutPath</key>
  <string>__TRADEBOT_ROOT__/logs/daily_summary.out</string>
  <key>StandardErrorPath</key>
  <string>__TRADEBOT_ROOT__/logs/daily_summary.err</string>
</dict>
</plist>
