# tradebot cron schedule — all times ET (handled by TZ= below).
#
# INSTALL (Mac or Linux):
#   1) Edit the TRADEBOT path below to your absolute repo path.
#   2) crontab /absolute/path/to/deploy/cron/crontab.example
#      (or: crontab -e  and paste the contents)
#   3) Verify:  crontab -l
#   4) Tail logs:  tail -f $TRADEBOT/logs/tradebot.out
#
# IMPORTANT on macOS: give cron full-disk access in
#   System Settings → Privacy & Security → Full Disk Access → add `cron`
# otherwise it can't read files inside ~/Documents/...
#
# NB: cron does not source your shell rc. Anything in .zshrc (e.g. aliases)
# will not apply. That's why we use absolute paths and the tradebotctl wrapper.

TZ=America/New_York
TRADEBOT=/ABSOLUTE/PATH/TO/tradebot
CTL=$TRADEBOT/scripts/tradebotctl.sh

# ---------------- live loop (Mon–Fri) ----------------

# 7:00 ET Mon-Fri → refresh earnings + FDA catalyst calendar BEFORE the bot starts
0  7  * * 1-5   $CTL catalysts > $TRADEBOT/logs/catalysts.$(date +\%Y\%m\%d).log 2>&1

# 9:25 ET Mon-Fri → start the paper loop (first tick runs around 9:30)
25 9  * * 1-5   $CTL start >> $TRADEBOT/logs/cron.out 2>&1

# 16:05 ET Mon-Fri → stop. The EOD-sweep already flat-closes everything at 15:45
# inside the bot; this is just tidy shutdown.
5  16 * * 1-5   $CTL stop  >> $TRADEBOT/logs/cron.out 2>&1

# ---------------- nightly (Mon–Fri evening) ----------------

# 18:00 ET Mon–Fri → recompute priors from the last 30 days of realized trades
0 18 * * 1-5    $CTL priors --days 30 --min-trades 30 >> $TRADEBOT/logs/priors.$(date +\%Y\%m\%d).log 2>&1

# 22:00 ET Mon–Fri → walk-forward summary, 8 most recent windows
0 22 * * 1-5    $CTL walkforward --max-windows 8 >> $TRADEBOT/logs/walkforward.$(date +\%Y\%m\%d).log 2>&1

# ---------------- weekly ----------------

# Sunday 20:00 ET → longer walk-forward report (quarterly-window sizes)
0 20 * * 0      $CTL walkforward --train-days 365 --test-days 63 --max-windows 12 >> $TRADEBOT/logs/walkforward_weekly.$(date +\%Y\%m\%d).log 2>&1

# Sunday 21:00 ET → propose ensemble weight nudges from last 30d (human review required)
0 21 * * 0      $CTL propose-weights --days 30 >> $TRADEBOT/logs/propose_weights.$(date +\%Y\%m\%d).log 2>&1

# Sunday 21:30 ET → signal orthogonalization: detect correlated signals
30 21 * * 0     $CTL orthogonalize --days 30 >> $TRADEBOT/logs/orthogonalize.$(date +\%Y\%m\%d).log 2>&1

# Every market-open morning 08:30 ET → Monte Carlo VaR on open book
30 8  * * 1-5   $CTL var --horizon-days 1 --n-paths 10000 >> $TRADEBOT/logs/var.$(date +\%Y\%m\%d).log 2>&1

# Sunday 22:30 ET → LSTM feature drift monitor (after weekly retrain)
30 22 * * 0     $CTL drift --days 7 >> $TRADEBOT/logs/drift.$(date +\%Y\%m\%d).log 2>&1

# Every 15 min during market hours → resolve LSTM predictions whose horizon elapsed
*/15 9-16 * * 1-5  $CTL resolve-ml > $TRADEBOT/logs/resolve_ml.out 2>&1

# 16:30 ET Mon-Fri → daily EOD snapshot (trades, slippage keep/tune, attribution)
30 16 * * 1-5   $CTL daily-report --days 1 >> $TRADEBOT/logs/daily_report.$(date +\%Y\%m\%d).log 2>&1

# 17:00 ET Mon-Fri → weekly slippage calibration report (human-review; auto-cal
# still runs inside the bot on its own schedule every hour / day)
0  17 * * 1-5   $CTL calibrate --days 7 >> $TRADEBOT/logs/calibrate.$(date +\%Y\%m\%d).log 2>&1

# 19:00 ET Mon-Fri → LSTM calibration report (post-resolve)
0 19 * * 1-5    $CTL analyze-ml --days 14 > $TRADEBOT/logs/ml_analysis.$(date +\%Y\%m\%d).log 2>&1

# 19:15 ET Mon-Fri → Ensemble decisions analysis (regime × win rate)
15 19 * * 1-5   $CTL analyze-ensemble --days 14 > $TRADEBOT/logs/ensemble_analysis.$(date +\%Y\%m\%d).log 2>&1

# Sunday 23:00 ET → retrain LSTM on last year; restart bot Mon 07:30 via the
# standard `start`/`stop` pair (the retrained checkpoint is picked up at start).
0 23 * * 0      $CTL train-lstm --days 365 --timeframe-min 5 --epochs 30 >> $TRADEBOT/logs/train_lstm.$(date +\%Y\%m\%d).log 2>&1

# ---------------- safety ----------------

# Every hour during market hours: if PID file is stale but process gone, clear it.
# The wrapper is idempotent so a stray `start` won't spawn a duplicate.
0,30 9-15 * * 1-5 $CTL status > /dev/null 2>&1 || true
